generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  image       String
  category    String
  sold        Boolean  @default(false)
  sellerId    String
  createdAt   DateTime @default(now())
  seller      User     @relation(fields: [sellerId], references: [id])
}

enum Role {
  USER
  ADMIN
}
